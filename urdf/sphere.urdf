<?xml version="1.0"?>
<robot name="visual_sphere">

  <link name="sphere_link">

    <visual>
      <geometry>
        <sphere radius="0.15"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>

    <inertial>
      <mass value="0.0001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>

    <kinematic>true</kinematic>
  </link>

</robot>
